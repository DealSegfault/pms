{
  "name": "pms-prop-trading",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently --kill-others-on-fail \"nodemon --signal SIGTERM --delay 1 --watch server --watch trading_engine_python server/index.js\" \"sleep 4 && vite --host\"",
    "build": "vite build",
    "server": "node --max-old-space-size=384 server/index.js",
    "server:prod": "NODE_ENV=production node --max-old-space-size=384 server/index.js",
    "client": "vite",
    "micro:live": "node debug_microstructure/server.mjs",
    "micro:label": "node debug_microstructure/tools/offline-labeler.mjs",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "test": "node --test server/tests/*.test.js",
    "test:server": "node --test server/tests/*.test.js",
    "test:unit": "node --test server/tests/*.test.js",
    "test:integration": "node --test server/tests/*.test.js",
    "test:live": "node --test server/tests/*.test.js",
    "test:auth": "node --test server/tests/*.test.js",
    "test:accounts": "node --test server/tests/*.test.js",
    "test:trading": "node --test server/tests/*.test.js"
  },
  "dependencies": {
    "@prisma/client": "^6.4.1",
    "@simplewebauthn/server": "^11.0.0",
    "bcryptjs": "^3.0.3",
    "ccxt": "^4.4.60",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^8.2.1",
    "ioredis": "^5.9.3",
    "jsonwebtoken": "^9.0.3",
    "node-cron": "^3.0.3",
    "pg-embedded": "^0.2.3",
    "uuid": "^11.1.0",
    "ws": "^8.18.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "nodemon": "^3.1.11",
    "prisma": "^6.4.1",
    "vite": "^6.1.0"
  }
}