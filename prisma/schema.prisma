generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(uuid())
  username      String   @unique
  passwordHash  String   @map("password_hash")
  role          String   @default("USER") // ADMIN, USER
  status        String   @default("PENDING") // PENDING, APPROVED, BANNED
  apiKey             String?  @unique @map("api_key") // For bot access
  currentChallenge   String?  @map("current_challenge") // Transient WebAuthn challenge
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  subAccounts          SubAccount[]
  webauthnCredentials  WebAuthnCredential[]

  @@map("users")
}

model SubAccount {
  id              String   @id @default(uuid())
  userId          String?  @map("user_id")
  routingPrefix   String?  @unique @map("routing_prefix")
  name            String
  type            String   @default("USER") // USER, BOT
  initialBalance  Float    @map("initial_balance")
  currentBalance  Float    @map("current_balance")
  status          String   @default("ACTIVE") // ACTIVE, FROZEN, LIQUIDATED
  liquidationMode String   @default("ADL_30") @map("liquidation_mode") // ADL_30, INSTANT_CLOSE, TAKEOVER
  maintenanceRate Float    @default(0.005) @map("maintenance_rate") // 0.5% maintenance margin
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user         User?           @relation(fields: [userId], references: [id])
  riskRule     RiskRule?
  botConfig    BotConfig?
  positions    VirtualPosition[]
  trades       TradeExecution[]
  balanceLogs  BalanceLog[]
  pendingOrders PendingOrder[]
  orderLifecycles OrderLifecycle[]
  fillFacts       FillFact[]
  strategySessions StrategySession[]
  tcaRollups      SubAccountTcaRollup[]
  strategyRollups StrategyTcaRollup[]
  algoRuntimeSessions AlgoRuntimeSession[]
  algoRuntimeCheckpoints AlgoRuntimeCheckpoint[]
  strategyPositionLots StrategyPositionLot[]
  strategyLotRealizations StrategyLotRealization[]
  strategySessionPnlSamples StrategySessionPnlSample[]
  strategySessionParamSamples StrategySessionParamSample[]

  @@index([userId, status])
  @@index([status])
  @@map("sub_accounts")
}

model RiskRule {
  id                 String  @id @default(uuid())
  subAccountId       String? @unique @map("sub_account_id")
  isGlobal           Boolean @default(false) @map("is_global")
  maxLeverage        Float   @default(100) @map("max_leverage")
  maxNotionalPerTrade Float  @default(200) @map("max_notional_per_trade")
  maxTotalExposure   Float   @default(500) @map("max_total_exposure")
  liquidationThreshold Float @default(0.90) @map("liquidation_threshold")
  
  subAccount SubAccount? @relation(fields: [subAccountId], references: [id])

  @@index([isGlobal])
  @@map("risk_rules")
}

model VirtualPosition {
  id             String   @id @default(uuid())
  subAccountId   String   @map("sub_account_id")
  symbol         String
  side           String   // LONG, SHORT
  entryPrice     Float    @map("entry_price")
  quantity       Float
  notional       Float
  leverage       Float
  margin         Float
  liquidationPrice Float  @map("liquidation_price")
  status         String   @default("OPEN") // OPEN, CLOSED, LIQUIDATED, TAKEN_OVER
  realizedPnl    Float?   @map("realized_pnl")
  takenOver      Boolean  @default(false) @map("taken_over")
  takenOverBy    String?  @map("taken_over_by")
  takenOverAt    DateTime? @map("taken_over_at")
  openedAt       DateTime @default(now()) @map("opened_at")
  closedAt       DateTime? @map("closed_at")

  subAccount SubAccount       @relation(fields: [subAccountId], references: [id])
  trades     TradeExecution[]

  @@index([subAccountId, status])
  @@index([symbol, status])
  @@index([subAccountId, symbol, side, status])
  @@map("virtual_positions")
}

model TradeExecution {
  id              String   @id @default(uuid())
  subAccountId    String   @map("sub_account_id")
  positionId      String?  @map("position_id")
  exchangeOrderId String?  @map("exchange_order_id")
  clientOrderId   String?  @map("client_order_id")
  symbol          String
  side            String   // BUY, SELL
  type            String   // MARKET, LIMIT
  price           Float
  quantity        Float
  notional        Float
  fee             Float    @default(0)
  realizedPnl     Float?   @map("realized_pnl")
  action          String   // OPEN, CLOSE, LIQUIDATE, ADD
  originType      String   @default("MANUAL") @map("origin_type") // MANUAL, BOT, API
  status          String   @default("FILLED") // PENDING, FILLED, FAILED, CANCELLED
  signature       String
  timestamp       DateTime @default(now())

  subAccount SubAccount       @relation(fields: [subAccountId], references: [id])
  position   VirtualPosition? @relation(fields: [positionId], references: [id])

  @@index([subAccountId, timestamp])
  @@index([subAccountId, status, timestamp])
  @@index([subAccountId, symbol, timestamp])
  @@index([exchangeOrderId])
  @@map("trade_executions")
}

model BalanceLog {
  id            String   @id @default(uuid())
  subAccountId  String   @map("sub_account_id")
  balanceBefore Float    @map("balance_before")
  balanceAfter  Float    @map("balance_after")
  changeAmount  Float    @map("change_amount")
  reason        String
  tradeId       String?  @map("trade_id")
  timestamp     DateTime @default(now())

  subAccount SubAccount @relation(fields: [subAccountId], references: [id])

  @@index([subAccountId, timestamp])
  @@map("balance_logs")
}

model PendingOrder {
  id              String    @id @default(uuid())
  subAccountId    String    @map("sub_account_id")
  clientOrderId   String?   @unique @map("client_order_id")
  symbol          String
  side            String    // LONG, SHORT
  type            String    @default("LIMIT") // LIMIT, STOP_MARKET, TAKE_PROFIT_MARKET
  price           Float     // limit/trigger price
  quantity        Float
  leverage        Float
  exchangeOrderId String?   @map("exchange_order_id")
  origin          String    @default("MANUAL")  // MANUAL, CHASE, SCALPER, TWAP, TRAIL_STOP, BOT
  parentId        String?   @map("parent_id")   // chase_id, scalper_id, etc.
  status          String    @default("PENDING") // PENDING, FILLED, CANCELLED, EXPIRED
  createdAt       DateTime  @default(now()) @map("created_at")
  filledAt        DateTime? @map("filled_at")
  cancelledAt     DateTime? @map("cancelled_at")

  subAccount SubAccount @relation(fields: [subAccountId], references: [id])

  @@index([clientOrderId])
  @@index([exchangeOrderId])
  @@index([status, type])
  @@index([subAccountId, status])
  @@map("pending_orders")
}

model OrderLifecycle {
  id                  String   @id @default(uuid())
  executionScope      String   @default("SUB_ACCOUNT") @map("execution_scope")
  subAccountId        String?  @map("sub_account_id")
  venue               String   @default("BINANCE_FUTURES")
  venueAccountKey     String   @default("binance:futures:main") @map("venue_account_key")
  ownershipConfidence String   @default("HARD") @map("ownership_confidence")
  originPath          String   @default("PYTHON_CMD") @map("origin_path")
  strategyType        String?  @map("strategy_type")
  strategySessionId   String?  @map("strategy_session_id")
  parentStrategySessionId String? @map("parent_strategy_session_id")
  rootStrategySessionId String? @map("root_strategy_session_id")
  parentId            String?  @map("parent_id")
  clientOrderId       String?  @map("client_order_id")
  exchangeOrderId     String?  @map("exchange_order_id")
  symbol              String?
  side                String?
  orderType           String?  @map("order_type")
  orderRole           String   @default("UNKNOWN") @map("order_role")
  reduceOnly          Boolean  @default(false) @map("reduce_only")
  requestedQty        Float?   @map("requested_qty")
  limitPrice          Float?   @map("limit_price")
  decisionBid         Float?   @map("decision_bid")
  decisionAsk         Float?   @map("decision_ask")
  decisionMid         Float?   @map("decision_mid")
  decisionSpreadBps   Float?   @map("decision_spread_bps")
  intentTs            DateTime? @map("intent_ts")
  ackTs               DateTime? @map("ack_ts")
  firstFillTs         DateTime? @map("first_fill_ts")
  doneTs              DateTime? @map("done_ts")
  finalStatus         String?  @map("final_status")
  filledQty           Float    @default(0) @map("filled_qty")
  avgFillPrice        Float?   @map("avg_fill_price")
  repriceCount        Int      @default(0) @map("reprice_count")
  reconciliationStatus String  @default("PENDING") @map("reconciliation_status")
  reconciliationReason String? @map("reconciliation_reason")
  lastReconciledAt    DateTime? @map("last_reconciled_at")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  subAccount      SubAccount?      @relation(fields: [subAccountId], references: [id])
  strategySession StrategySession? @relation(fields: [strategySessionId], references: [id])
  events          OrderLifecycleEvent[]
  fillFacts       FillFact[]

  @@unique([venue, venueAccountKey, clientOrderId])
  @@unique([venue, venueAccountKey, exchangeOrderId])
  @@index([subAccountId, createdAt])
  @@index([subAccountId, rootStrategySessionId, createdAt])
  @@index([clientOrderId])
  @@index([exchangeOrderId])
  @@index([symbol, createdAt])
  @@index([rootStrategySessionId, createdAt])
  @@index([reconciliationStatus, updatedAt])
  @@map("order_lifecycles")
}

model OrderLifecycleEvent {
  id           String   @id @default(uuid())
  lifecycleId  String   @map("lifecycle_id")
  streamEventId String  @unique @map("stream_event_id")
  eventType    String   @map("event_type")
  sourceTs     DateTime? @map("source_ts")
  ingestedTs   DateTime? @map("ingested_ts")
  payloadJson  String   @map("payload_json")
  createdAt    DateTime @default(now()) @map("created_at")

  lifecycle OrderLifecycle @relation(fields: [lifecycleId], references: [id])

  @@index([lifecycleId, createdAt])
  @@index([eventType, sourceTs])
  @@map("order_lifecycle_events")
}

model AlgoLineageEdge {
  id                  String   @id @default(uuid())
  executionScope      String   @default("SUB_ACCOUNT") @map("execution_scope")
  subAccountId        String?  @map("sub_account_id")
  ownershipConfidence String   @default("HARD") @map("ownership_confidence")
  parentNodeType      String   @map("parent_node_type")
  parentNodeId        String   @map("parent_node_id")
  childNodeType       String   @map("child_node_type")
  childNodeId         String   @map("child_node_id")
  relationType        String   @map("relation_type")
  sourceEventId       String?  @map("source_event_id")
  sourceTs            DateTime? @map("source_ts")
  ingestedTs          DateTime? @map("ingested_ts")
  createdAt           DateTime @default(now()) @map("created_at")

  @@unique([parentNodeType, parentNodeId, childNodeType, childNodeId, relationType])
  @@index([subAccountId, sourceTs])
  @@index([parentNodeType, parentNodeId])
  @@index([childNodeType, childNodeId])
  @@map("algo_lineage_edges")
}

model MarketQuote {
  id        String   @id @default(uuid())
  symbol    String
  ts        DateTime
  bid       Float
  ask       Float
  mid       Float
  spreadBps Float?   @map("spread_bps")
  source    String   @default("L1")
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([symbol, ts])
  @@index([symbol, ts])
  @@map("market_quotes")
}

model FillFact {
  id                  String   @id @default(uuid())
  lifecycleId         String   @map("lifecycle_id")
  subAccountId        String?  @map("sub_account_id")
  sourceEventId       String?  @unique @map("source_event_id")
  executionScope      String   @default("SUB_ACCOUNT") @map("execution_scope")
  ownershipConfidence String   @default("HARD") @map("ownership_confidence")
  symbol              String
  side                String?
  fillTs              DateTime @map("fill_ts")
  fillQty             Float    @map("fill_qty")
  fillPrice           Float    @map("fill_price")
  fillBid             Float?   @map("fill_bid")
  fillAsk             Float?   @map("fill_ask")
  fillMid             Float?   @map("fill_mid")
  fillSpreadBps       Float?   @map("fill_spread_bps")
  sampledAt           DateTime? @map("sampled_at")
  fee                 Float    @default(0)
  makerTaker          String?  @map("maker_taker")
  originType          String   @default("MANUAL") @map("origin_type")
  createdAt           DateTime @default(now()) @map("created_at")

  lifecycle OrderLifecycle @relation(fields: [lifecycleId], references: [id])
  subAccount SubAccount?    @relation(fields: [subAccountId], references: [id])
  markouts   FillMarkout[]

  @@index([subAccountId, fillTs])
  @@index([symbol, fillTs])
  @@index([lifecycleId, fillTs])
  @@map("fill_facts")
}

model FillMarkout {
  id         String   @id @default(uuid())
  fillFactId String   @map("fill_fact_id")
  horizonMs  Int      @map("horizon_ms")
  measuredTs DateTime? @map("measured_ts")
  midPrice   Float?   @map("mid_price")
  markPrice  Float?   @map("mark_price")
  markoutBps Float?   @map("markout_bps")
  createdAt  DateTime @default(now()) @map("created_at")

  fillFact FillFact @relation(fields: [fillFactId], references: [id])

  @@unique([fillFactId, horizonMs])
  @@map("fill_markouts")
}

model StrategySession {
  id           String   @id
  subAccountId String?  @map("sub_account_id")
  origin       String   @default("MANUAL")
  strategyType String?  @map("strategy_type")
  parentStrategySessionId String? @map("parent_strategy_session_id")
  rootStrategySessionId   String? @map("root_strategy_session_id")
  sessionRole   String   @default("STANDALONE") @map("session_role")
  symbol       String?
  side         String?
  startedAt    DateTime? @map("started_at")
  endedAt      DateTime? @map("ended_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  subAccount SubAccount?      @relation(fields: [subAccountId], references: [id])
  lifecycles OrderLifecycle[]
  rollups    StrategyTcaRollup[]
  runtimeSessions AlgoRuntimeSession[]
  runtimeCheckpoints AlgoRuntimeCheckpoint[]
  positionLots StrategyPositionLot[]
  lotRealizations StrategyLotRealization[]
  pnlSamples StrategySessionPnlSample[]
  paramSamples StrategySessionParamSample[]

  @@index([subAccountId, startedAt])
  @@index([rootStrategySessionId, startedAt])
  @@map("strategy_sessions")
}

model SubAccountTcaRollup {
  id                  String   @id @default(uuid())
  subAccountId        String   @map("sub_account_id")
  executionScope      String   @default("SUB_ACCOUNT") @map("execution_scope")
  ownershipConfidence String   @default("HARD") @map("ownership_confidence")
  qualityByRoleJson   String?  @map("quality_by_role_json")
  orderCount          Int      @default(0) @map("order_count")
  terminalOrderCount  Int      @default(0) @map("terminal_order_count")
  fillCount           Int      @default(0) @map("fill_count")
  cancelCount         Int      @default(0) @map("cancel_count")
  rejectCount         Int      @default(0) @map("reject_count")
  totalRequestedQty   Float    @default(0) @map("total_requested_qty")
  totalFilledQty      Float    @default(0) @map("total_filled_qty")
  totalFillNotional   Float    @default(0) @map("total_fill_notional")
  fillRatio           Float?   @map("fill_ratio")
  cancelToFillRatio   Float?   @map("cancel_to_fill_ratio")
  avgArrivalSlippageBps Float? @map("avg_arrival_slippage_bps")
  avgAckLatencyMs     Float?   @map("avg_ack_latency_ms")
  avgWorkingTimeMs    Float?   @map("avg_working_time_ms")
  avgMarkout1sBps     Float?   @map("avg_markout_1s_bps")
  avgMarkout5sBps     Float?   @map("avg_markout_5s_bps")
  avgMarkout30sBps    Float?   @map("avg_markout_30s_bps")
  realizedPnl         Float    @default(0) @map("realized_pnl")
  unrealizedPnl       Float    @default(0) @map("unrealized_pnl")
  netPnl              Float    @default(0) @map("net_pnl")
  feesTotal           Float    @default(0) @map("fees_total")
  lastSampledAt       DateTime? @map("last_sampled_at")
  totalRepriceCount   Int      @default(0) @map("total_reprice_count")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  subAccount SubAccount @relation(fields: [subAccountId], references: [id])

  @@unique([subAccountId, executionScope, ownershipConfidence])
  @@index([executionScope, ownershipConfidence])
  @@map("sub_account_tca_rollups")
}

model StrategyTcaRollup {
  id                  String   @id @default(uuid())
  strategySessionId   String   @map("strategy_session_id")
  subAccountId        String?  @map("sub_account_id")
  strategyType        String?  @map("strategy_type")
  rollupLevel         String   @default("SESSION") @map("rollup_level")
  executionScope      String   @default("SUB_ACCOUNT") @map("execution_scope")
  ownershipConfidence String   @default("HARD") @map("ownership_confidence")
  qualityByRoleJson   String?  @map("quality_by_role_json")
  orderCount          Int      @default(0) @map("order_count")
  terminalOrderCount  Int      @default(0) @map("terminal_order_count")
  fillCount           Int      @default(0) @map("fill_count")
  cancelCount         Int      @default(0) @map("cancel_count")
  rejectCount         Int      @default(0) @map("reject_count")
  totalRequestedQty   Float    @default(0) @map("total_requested_qty")
  totalFilledQty      Float    @default(0) @map("total_filled_qty")
  totalFillNotional   Float    @default(0) @map("total_fill_notional")
  fillRatio           Float?   @map("fill_ratio")
  cancelToFillRatio   Float?   @map("cancel_to_fill_ratio")
  avgArrivalSlippageBps Float? @map("avg_arrival_slippage_bps")
  avgAckLatencyMs     Float?   @map("avg_ack_latency_ms")
  avgWorkingTimeMs    Float?   @map("avg_working_time_ms")
  avgMarkout1sBps     Float?   @map("avg_markout_1s_bps")
  avgMarkout5sBps     Float?   @map("avg_markout_5s_bps")
  avgMarkout30sBps    Float?   @map("avg_markout_30s_bps")
  realizedPnl         Float    @default(0) @map("realized_pnl")
  unrealizedPnl       Float    @default(0) @map("unrealized_pnl")
  netPnl              Float    @default(0) @map("net_pnl")
  feesTotal           Float    @default(0) @map("fees_total")
  openQty             Float    @default(0) @map("open_qty")
  openNotional        Float    @default(0) @map("open_notional")
  closeCount          Int      @default(0) @map("close_count")
  winCount            Int      @default(0) @map("win_count")
  lossCount           Int      @default(0) @map("loss_count")
  winRate             Float?   @map("win_rate")
  maxDrawdownPnl      Float?   @map("max_drawdown_pnl")
  maxRunupPnl         Float?   @map("max_runup_pnl")
  lastSampledAt       DateTime? @map("last_sampled_at")
  totalRepriceCount   Int      @default(0) @map("total_reprice_count")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  strategySession StrategySession @relation(fields: [strategySessionId], references: [id])
  subAccount      SubAccount?     @relation(fields: [subAccountId], references: [id])

  @@unique([strategySessionId, executionScope, ownershipConfidence, rollupLevel])
  @@index([executionScope, ownershipConfidence])
  @@map("strategy_tca_rollups")
}

model TcaWorkerCursor {
  workerKey          String   @id @map("worker_key")
  cursorJson         String?  @map("cursor_json")
  lastRunStartedAt   DateTime? @map("last_run_started_at")
  lastRunCompletedAt DateTime? @map("last_run_completed_at")
  lastSuccessAt      DateTime? @map("last_success_at")
  lastRunMetaJson    String?  @map("last_run_meta_json")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@map("tca_worker_cursors")
}

model TcaAnomaly {
  id                    String   @id @default(uuid())
  anomalyKey            String   @unique @map("anomaly_key")
  anomalyType           String   @map("anomaly_type")
  subAccountId          String?  @map("sub_account_id")
  rootStrategySessionId String?  @map("root_strategy_session_id")
  strategySessionId     String?  @map("strategy_session_id")
  lifecycleId           String?  @map("lifecycle_id")
  fillFactId            String?  @map("fill_fact_id")
  severity              String   @default("WARN")
  status                String   @default("OPEN")
  payloadJson           String?  @map("payload_json")
  sourceTs              DateTime? @map("source_ts")
  firstSeenAt           DateTime @default(now()) @map("first_seen_at")
  lastSeenAt            DateTime @default(now()) @map("last_seen_at")
  resolvedAt            DateTime? @map("resolved_at")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  @@index([subAccountId, status, anomalyType])
  @@index([subAccountId, rootStrategySessionId, anomalyType, status, lastSeenAt])
  @@index([rootStrategySessionId, status, anomalyType])
  @@index([strategySessionId, status, anomalyType])
  @@index([lifecycleId, anomalyType])
  @@index([fillFactId, anomalyType])
  @@map("tca_anomalies")
}

model AlgoRuntimeSession {
  strategySessionId String   @id @map("strategy_session_id")
  subAccountId      String   @map("sub_account_id")
  strategyType      String   @map("strategy_type")
  status            String
  resumePolicy      String   @default("RECREATE_CHILD_ORDERS") @map("resume_policy")
  startedAt         DateTime? @map("started_at")
  stoppedAt         DateTime? @map("stopped_at")
  lastHeartbeatAt   DateTime? @map("last_heartbeat_at")
  latestCheckpointId String? @map("latest_checkpoint_id")
  initialConfigJson String?  @map("initial_config_json")
  currentConfigJson String?  @map("current_config_json")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  subAccount      SubAccount @relation(fields: [subAccountId], references: [id])
  strategySession StrategySession @relation(fields: [strategySessionId], references: [id])

  @@index([subAccountId, updatedAt])
  @@index([status, updatedAt])
  @@map("algo_runtime_sessions")
}

model AlgoRuntimeCheckpoint {
  id               String   @id @default(uuid())
  strategySessionId String  @map("strategy_session_id")
  subAccountId     String   @map("sub_account_id")
  strategyType     String   @map("strategy_type")
  checkpointSeq    Int      @map("checkpoint_seq")
  checkpointTs     DateTime @map("checkpoint_ts")
  checkpointReason String   @map("checkpoint_reason")
  status           String
  snapshotJson     String   @map("snapshot_json")
  createdAt        DateTime @default(now()) @map("created_at")

  subAccount      SubAccount @relation(fields: [subAccountId], references: [id])
  strategySession StrategySession @relation(fields: [strategySessionId], references: [id])

  @@unique([strategySessionId, checkpointSeq])
  @@index([subAccountId, checkpointTs])
  @@index([strategySessionId, checkpointTs])
  @@index([strategySessionId, checkpointTs, checkpointSeq])
  @@map("algo_runtime_checkpoints")
}

model StrategyPositionLot {
  id                    String   @id @default(uuid())
  subAccountId          String   @map("sub_account_id")
  rootStrategySessionId String   @map("root_strategy_session_id")
  sourceStrategySessionId String @map("source_strategy_session_id")
  symbol                String
  positionSide          String   @map("position_side")
  sourceLifecycleId     String?  @map("source_lifecycle_id")
  sourceFillFactId      String?  @map("source_fill_fact_id")
  openedTs              DateTime @map("opened_ts")
  openQty               Float    @map("open_qty")
  remainingQty          Float    @map("remaining_qty")
  openPrice             Float    @map("open_price")
  openFee               Float    @default(0) @map("open_fee")
  status                String   @default("OPEN")
  closedTs              DateTime? @map("closed_ts")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  subAccount      SubAccount @relation(fields: [subAccountId], references: [id])
  strategySession StrategySession @relation(fields: [rootStrategySessionId], references: [id])
  realizations    StrategyLotRealization[]

  @@index([subAccountId, openedTs])
  @@index([subAccountId, rootStrategySessionId, openedTs])
  @@index([rootStrategySessionId, symbol, positionSide, status])
  @@index([sourceFillFactId])
  @@map("strategy_position_lots")
}

model StrategyLotRealization {
  id                    String   @id @default(uuid())
  lotId                 String   @map("lot_id")
  subAccountId          String   @map("sub_account_id")
  rootStrategySessionId String   @map("root_strategy_session_id")
  sourceStrategySessionId String @map("source_strategy_session_id")
  closeLifecycleId      String?  @map("close_lifecycle_id")
  closeFillFactId       String?  @map("close_fill_fact_id")
  realizedTs            DateTime @map("realized_ts")
  allocatedQty          Float    @map("allocated_qty")
  openPrice             Float    @map("open_price")
  closePrice            Float    @map("close_price")
  grossRealizedPnl      Float    @map("gross_realized_pnl")
  openFeeAllocated      Float    @default(0) @map("open_fee_allocated")
  closeFeeAllocated     Float    @default(0) @map("close_fee_allocated")
  netRealizedPnl        Float    @map("net_realized_pnl")
  createdAt             DateTime @default(now()) @map("created_at")

  lot            StrategyPositionLot @relation(fields: [lotId], references: [id])
  subAccount     SubAccount @relation(fields: [subAccountId], references: [id])
  strategySession StrategySession @relation(fields: [rootStrategySessionId], references: [id])

  @@index([subAccountId, realizedTs])
  @@index([subAccountId, rootStrategySessionId, realizedTs])
  @@index([rootStrategySessionId, realizedTs])
  @@index([closeFillFactId])
  @@map("strategy_lot_realizations")
}

model StrategySessionPnlSample {
  id                String   @id @default(uuid())
  strategySessionId String   @map("strategy_session_id")
  subAccountId      String   @map("sub_account_id")
  sampledAt         DateTime @map("sampled_at")
  markPrice         Float?   @map("mark_price")
  realizedPnl       Float    @default(0) @map("realized_pnl")
  unrealizedPnl     Float    @default(0) @map("unrealized_pnl")
  netPnl            Float    @default(0) @map("net_pnl")
  feesTotal         Float    @default(0) @map("fees_total")
  openQty           Float    @default(0) @map("open_qty")
  openNotional      Float    @default(0) @map("open_notional")
  fillCount         Int      @default(0) @map("fill_count")
  closeCount        Int      @default(0) @map("close_count")
  winCount          Int      @default(0) @map("win_count")
  lossCount         Int      @default(0) @map("loss_count")
  createdAt         DateTime @default(now()) @map("created_at")

  subAccount      SubAccount @relation(fields: [subAccountId], references: [id])
  strategySession StrategySession @relation(fields: [strategySessionId], references: [id])

  @@unique([strategySessionId, sampledAt])
  @@index([subAccountId, sampledAt])
  @@index([strategySessionId, sampledAt])
  @@map("strategy_session_pnl_samples")
}

model StrategySessionParamSample {
  id                   String   @id @default(uuid())
  strategySessionId    String   @map("strategy_session_id")
  subAccountId         String   @map("sub_account_id")
  sampledAt            DateTime @map("sampled_at")
  sampleReason         String   @map("sample_reason")
  status               String?
